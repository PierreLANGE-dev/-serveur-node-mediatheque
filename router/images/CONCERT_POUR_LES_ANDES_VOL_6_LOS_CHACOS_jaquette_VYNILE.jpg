  <script type="text/ng-template" id="popinOuiNon.html">
    <div class="modal-header">
      <h3 class="modal-title" ng-cloak>{{titrePopin}}</h3>
      <div id="spinner" ng-show="loading">
        <!-- <img id="img-spinner" src="images/spin.gif" /> -->
        <h1 class="spinner spinner-1"></h1>
      </div>
      
    </div>
    <div class="modal-body">
    </div>
    <div class="modal-footer">
      <button id="btnOuiNon" class="btn btn-primary" type="button" ng-keypress="($event.which === 13)?ok():0" ng-click="ok()">Oui</button>
      <button class="btn btn-warning" type="button" ng-click="cancel()">Non</button>
    </div>
  </script>

  <script type="text/ng-template" id="popinOuiNonTplSave.html">
    <div class="modal-header">
      <h3 class="modal-title" ng-cloak>{{titrePopin}}</h3>
      <div id="spinner" ng-show="loading">
        <!-- <img id="img-spinner" src="images/spin.gif" /> -->
        <h1 class="spinner spinner-1"></h1>
      </div>
      
    </div>
    <div class="modal-body">
    </div>
    <div class="modal-footer">
      <button id="btnOuiNon" class="btn btn-primary" type="button" ng-keypress="($event.which === 13)?ok():0" ng-click="okSave()">Oui</button>
      <button class="btn btn-warning" type="button" ng-click="cancel()">Non</button>
    </div>
  </script>

  <script type="text/ng-template" id="prompt.html">
    <div class="modal-header">
      <h3 class="modal-title" ng-cloak>{{titrePopin}}</h3> 
    </div>
    <div class="modal-body">
      <form>
        <div class="form-group">
          <label for="recipient-name" class="form-control-label recherche" ng-bind-html="titreLabel"></label>
          <input type="text" focus="true" class="form-control" id="recipient-name" ng-model="searchTerm" autocomplete="on" autocorrect="on" ng-keypress="($event.which === 13)?okPrompt(searchTerm):0">
        </div>
      </form>
    </div>
    <div class="modal-footer">
      <button class="btn btn-primary" type="button" ng-keypress="($event.which === 13)?okPrompt(searchTerm):0" ng-click="okPrompt(searchTerm)">valider</button>
      <button class="btn btn-warning" type="button" ng-click="cancel()">Non</button>
    </div>
  </script>

  <script type="text/ng-template" id="search.html">
    <div class="corps container">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" ng-click="cancel()" aria-label="Close">
        <span aria-hidden="true">&times;</span>
        </button>
        <h3 class="modal-title">{{titrePopin}}</h3>
      </div>
      <div class="modal-body" id="modal-body">
        <h5 ng-cloak>Voici le résutat de la recherche pour : {{searchFilterModal}}</h5>        
        <ul class="container dumemeentete">
          <li class="headertris ">
            <span class="col-md-1 musiciens head" id="TypeM"><a ng-click="changeChevronM('TypeM') ">Type</a></span>
            <span class="col-md-3 musiciens head" id="ArtisteM"><a ng-click="changeChevronM('ArtisteM') ">Artiste</a></span>
            <span class="col-md-3 musiciens head" id="TitreM"><a ng-click="changeChevronM('TitreM') ">Titre</a></span>
            <span class="col-md-1 musiciens head" id="AnneeM"><a ng-click="changeChevronM('AnneeM') ">Annee</a></span>
            <span class="col-md-2 musiciens head" id="GenreM"><a ng-click="changeChevronM('GenreM') ">Genre</a></span>
            <span class="col-md-2 musiciens head" id="EmplacementM"><a ng-click="changeChevronM('EmplacementM') ">Emplacement</a></span>
          </li>
        </ul>
        <ul class="dumeme ">
          <!-- | filter:search -->
          <li class="dumemetris hoverdumemetris " ng-repeat="fiche in filtered = (searchFicheArrayModal | filter: searchFilterModal : searchFilterModalCond)">

            <a href="# " data-dismiss="modal " data-ng-click="ok(searchFicheArrayModal.indexOf(fiche)+1) ">
              <div class="colleft col-md-1 musiciens Type" id="myTypeTextM{{$index}}" ng-cloak>{{fiche.Type || "- "}}</div>
              <div class="col-md-3 musiciens Artiste" id="myArtisteTextM{{$index}}" ng-cloak>{{fiche.Artiste || "- "}}</div>
              <div class="col-md-3 musiciens Titre" id="myTitreTextM{{$index}}" ng-cloak>{{fiche.Titre || "- "}}</div>
              <div class="col-md-1 musiciens Genre" ng-cloak>{{fiche.Annee || "- "}}</div>
              <div class="col-md-2 musiciens" id="myGenreTextM{{$index}}" ng-cloak>{{fiche.Genre || "- "}}</div>
              <div class="col-md-2 musiciens Emplacement colright" id="myEmplacementTextM{{$index}}" ng-cloak>{{fiche.Emplacement || "- "}}</div>

            </a>
          </li>
        </ul>
        <h5><span ng-if="filtered.length > 0">{{filtered.length}}</span> <ng-pluralize count="filtered.length" offset=1 when="{'0': 'Pas de fiche trouvée','1': 'fiche trouvée', 'other': 'fiches trouvées'}"></ng-pluralize></h5>     
      </div>
      
      <div class="modal-footer ">  
                
        <button class="btn btn-warning " type="button " ng-click="cancel() ">Close</button>
      </div>
    </div>
  </script>

